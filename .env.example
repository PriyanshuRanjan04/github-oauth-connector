# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to `.env` and fill in your actual values
# NEVER commit your real .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create one at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── OAuth Callback URL ─────────────────────────────────────────────────────────
# Local development (default):
CALLBACK_URL=http://localhost:8000/auth/callback
# Render deployment — swap this in after deploy:
# CALLBACK_URL=https://your-app-name.onrender.com/auth/callback

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Local:
# MONGO_URI=mongodb://localhost:27017
# MongoDB Atlas (recommended):
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/github_connector?retryWrites=true&w=majority
